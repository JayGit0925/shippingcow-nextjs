# ============================================================
# SHIPPING COW — Environment variables
# Copy to .env.local and fill in your values.
# Never commit .env.local — it contains secrets.
# ============================================================

# --- Database (REQUIRED) -------------------------------------
# SQLite (default, zero-config):
DATABASE_URL=file:./data/shippingcow.sqlite

# Postgres (production — uncomment and fill in):
# DATABASE_URL=postgresql://user:password@host:5432/shippingcow

# --- LiteLLM / AI chat (REQUIRED for /api/chat) -------------
# Point to your LiteLLM proxy instance.
# Docs: https://docs.litellm.ai/docs/proxy/quick_start
LITELLM_URL=http://localhost:4000

# API key for the LiteLLM proxy (leave blank if your proxy is open)
LITELLM_API_KEY=

# Model to use (any model your LiteLLM proxy supports)
LITELLM_MODEL=gpt-4o-mini

# --- App URL (REQUIRED for email reset links) ---------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Auth ---------------------------------------------------
# Generate: openssl rand -base64 48
JWT_SECRET=replace-this-with-a-long-random-string-at-least-48-chars

# --- Email (Resend — required for inquiry + reset emails) ---
# Sign up free at https://resend.com (100 emails/day on free tier)
RESEND_API_KEY=re_your_key_here
RESEND_FROM=Shipping Cow <onboarding@resend.dev>
INQUIRY_TO_EMAIL=you@yourdomain.com

# --- Admin dashboard ----------------------------------------
# Set to your email to unlock /admin
ADMIN_EMAIL=you@yourdomain.com
