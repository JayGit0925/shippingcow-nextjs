# ============================================================
# SHIPPING COW — Environment variables
# Copy to .env.local and fill in your values.
# Never commit .env.local — it contains secrets.
# ============================================================

# --- Database (REQUIRED) -------------------------------------
# Supabase Transaction Pooler (IPv4-compatible, recommended):
# user format: postgres.<project-ref>
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Supabase direct connection (IPv6 only):
# DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# --- Anthropic Claude AI chat (REQUIRED for /api/chat) ------
# Get your key at: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- App URL (REQUIRED for email reset links) ---------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Auth ---------------------------------------------------
# Generate: openssl rand -base64 48
JWT_SECRET=replace-this-with-a-long-random-string-at-least-48-chars

# --- Email (Resend — required for inquiry + reset emails) ---
# Sign up free at https://resend.com (100 emails/day on free tier)
RESEND_API_KEY=re_your_key_here
RESEND_FROM=Shipping Cow <onboarding@resend.dev>
INQUIRY_TO_EMAIL=you@yourdomain.com

# --- Admin dashboard ----------------------------------------
# Set to your email to unlock /admin
ADMIN_EMAIL=you@yourdomain.com

# --- Analytics (PostHog) ------------------------------------
# Sign up at https://posthog.com — get key from Project Settings → API keys
# Self-hosted: set NEXT_PUBLIC_POSTHOG_HOST to your instance URL (e.g. http://localhost:8080)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- n8n Webhook (optional — pipes completed leads to Twenty CRM) ---
# Get URL from your n8n workflow's Webhook trigger node
N8N_WEBHOOK_URL=http://localhost:5678/webhook/shippingcow-leads
