# ============================================================
# SHIPPING COW — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to git — it contains secrets.
# ============================================================

# --- JWT signing secret (REQUIRED) -------------------------------
# Used to sign auth tokens. Generate a strong random string.
# On Mac/Linux run: openssl rand -base64 48
# On Windows PowerShell: [Convert]::ToBase64String((1..48|%{Get-Random -Max 256}))
JWT_SECRET=replace-this-with-a-long-random-string-at-least-48-chars

# --- Resend email delivery (REQUIRED for inquiry emails) ---------
# 1. Sign up free at https://resend.com (100 emails/day free)
# 2. Verify your sending domain OR use their test domain for dev
# 3. Create an API key at https://resend.com/api-keys
# 4. Paste the key below (starts with "re_")
RESEND_API_KEY=re_your_key_here

# "From" address — must be a verified domain, or use onboarding@resend.dev while testing
RESEND_FROM=Shipping Cow <onboarding@resend.dev>

# Where inquiry emails should be delivered. This is YOUR inbox.
INQUIRY_TO_EMAIL=you@yourdomain.com

# --- App URL (optional, used in email links) ---------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Admin dashboard (optional) ----------------------------------
# Set to your email to unlock /admin — the inquiry management dashboard.
ADMIN_EMAIL=you@yourdomain.com

# --- Chat Widget v2 (optional but recommended) -------------------
# Telegram bot for lead handoff pings.
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot on Telegram → copy your numeric chat ID
#    (For a group: add bot to group, use group chat ID — starts with -100)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=your_numeric_chat_id
